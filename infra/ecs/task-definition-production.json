{
  "family": "gwanri-backend-production",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/gwanri-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "ACCOUNT_ID.dkr.ecr.ap-northeast-2.amazonaws.com/gwanri-wang-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",    "value": "production" },
        { "name": "PORT",        "value": "3001" },
        { "name": "DB_PORT",     "value": "5432" },
        { "name": "DB_NAME",     "value": "gwanri_wang" }
      ],
      "secrets": [
        { "name": "DB_HOST",              "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:gwanri/production/db:host::" },
        { "name": "DB_USERNAME",          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:gwanri/production/db:username::" },
        { "name": "DB_PASSWORD",          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:gwanri/production/db:password::" },
        { "name": "REDIS_HOST",           "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:gwanri/production/redis:host::" },
        { "name": "REDIS_PASSWORD",       "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:gwanri/production/redis:password::" },
        { "name": "JWT_ACCESS_SECRET",    "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:gwanri/production/jwt:accessSecret::" },
        { "name": "JWT_REFRESH_SECRET",   "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:gwanri/production/jwt:refreshSecret::" },
        { "name": "OPENAI_API_KEY",       "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:gwanri/production/openai:apiKey::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/gwanri-backend-production",
          "awslogs-region":        "ap-northeast-2",
          "awslogs-stream-prefix": "backend"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:3001/api/v1/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
