# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=gwanri_wang

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT_MS=30000

# AI Rate Limit (플랜별 하루 최대 요청 수)
AI_RATE_LIMIT_FREE=10
AI_RATE_LIMIT_BASIC=50
AI_RATE_LIMIT_PRO=200

# App
PORT=3001
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3 / Cloudflare R2 (파일 업로드)
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=gwanri-wang-files
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
# R2 사용 시: AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# 이메일 (Resend 권장)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@your-domain.com

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your_expo_access_token

# MinIO (로컬 개발용 S3 대체)
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
