{
  "name": "gwanri-wang-backend",
  "version": "1.0.0",
  "description": "B2B SaaS 직원 관리 플랫폼 백엔드",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js --dataSource ./data-source.ts",
    "migration:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create ./src/database/migrations/Migration",
    "migration:generate": "npm run typeorm migration:generate ./src/database/migrations/Migration",
    "migration:run": "npm run typeorm migration:run",
    "migration:revert": "npm run typeorm migration:revert",
    "migration:show": "npm run typeorm migration:show",
    "migration:run:prod": "node ./node_modules/.bin/typeorm migration:run --dataSource dist/data-source.prod.js",
    "migration:show:prod": "node ./node_modules/.bin/typeorm migration:show --dataSource dist/data-source.prod.js",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeds/seed.ts",
    "seed:demo": "ts-node -r tsconfig-paths/register src/database/seeds/demo.seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=test/",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^11.1.16",
    "@sentry/nestjs": "^10.43.0",
    "@sentry/profiling-node": "^10.43.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.0",
    "coolsms-node-sdk": "^2.1.0",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "date-fns": "^4.1.0",
    "expo-server-sdk": "^6.1.0",
    "helmet": "^8.1.0",
    "nest-winston": "^1.10.2",
    "openai": "^4.47.0",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.9.3",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "winston-cloudwatch": "^6.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^3.0.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1",
      "^expo-server-sdk$": "<rootDir>/test/__mocks__/expo-server-sdk.js",
      "^winston-cloudwatch$": "<rootDir>/test/__mocks__/winston-cloudwatch.js",
      "^resend$": "<rootDir>/test/__mocks__/resend.js"
    },
    "testTimeout": 30000,
    "setupFiles": [
      "<rootDir>/test/jest.setup.ts"
    ]
  }
}
