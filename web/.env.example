# ─── API ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─── Sentry (에러 추적) ──────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=        # 클라이언트 DSN (공개 가능)
SENTRY_DSN=                    # 서버 DSN (동일 값)
SENTRY_ORG=your-org            # sentry.io 조직 슬러그
SENTRY_PROJECT=gwanri-web      # sentry.io 프로젝트 슬러그
SENTRY_AUTH_TOKEN=             # Settings > Auth Tokens > Create New Token

# ─── 프로덕션 예시 ───────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.gwanriwang.com/api/v1
