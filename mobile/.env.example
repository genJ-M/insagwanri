# 모바일 앱 환경변수 (EXPO_PUBLIC_ 접두사 = 클라이언트에 노출됨)

# 백엔드 API URL
# 로컬: http://localhost:3001/api/v1
# 프로덕션: https://insagwanri-backend.onrender.com/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# Google OAuth (Google Cloud Console → iOS/Android 앱 클라이언트 ID)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=YOUR_IOS_GOOGLE_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=YOUR_ANDROID_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Kakao OAuth (Kakao Developers → 앱 키 → REST API 키)
EXPO_PUBLIC_KAKAO_CLIENT_ID=YOUR_KAKAO_REST_API_KEY
