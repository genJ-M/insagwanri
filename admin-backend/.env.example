# ── 서버 ──────────────────────────────────────
NODE_ENV=development
ADMIN_PORT=4001
ADMIN_FRONTEND_URL=http://localhost:4000

# ── DB (Customer와 동일 DB 공유) ────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=gwanriwang

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Admin JWT (Customer JWT와 완전 분리) ────────
ADMIN_JWT_SECRET=replace-with-64-char-random-string-for-admin
ADMIN_JWT_TEMP_SECRET=replace-with-64-char-random-string-for-temp

# ── IP 화이트리스트 (프로덕션: VPN CIDR) ───────
ADMIN_ALLOWED_IPS=10.0.0.0/8,127.0.0.1

# ── Toss Payments ─────────────────────────────
TOSS_PAYMENTS_SECRET_KEY=test_sk_...

# ── 빌링키 AES-256 암호화 키 (64자리 hex) ──────
BILLING_KEY_ENCRYPTION_KEY=replace-with-64-hex-chars

# ── Sentry (Admin 전용 DSN) ──────────────────
SENTRY_DSN=

# ── AWS CloudWatch 로그 ─────────────────────
AWS_CLOUDWATCH_GROUP=/gwanriwang/admin
AWS_REGION=ap-northeast-2
